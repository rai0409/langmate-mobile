// ============================================================
// EXAMPLE ONLY — NOT DEPLOYED
// ============================================================
// These rules describe the intended access model for LangMate.
// They have NOT been deployed and have NOT been tested against
// the Firestore emulator. Review and adapt before deploying with:
//   firebase deploy --only firestore:rules
// ============================================================

rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    // Main profiles always live at profiles/{uid}.
    match /profiles/{uid} {
      // Readable when discoverable, or by the owner.
      allow read: if signedIn()
        && (resource.data.isDiscoverable == true || request.auth.uid == uid);
      // Writable only by the owner.
      allow create, update: if signedIn() && request.auth.uid == uid;
      allow delete: if false;
    }

    // Swipe doc id is `${fromUid}_${toUid}`.
    match /swipes/{swipeId} {
      // Writable only by the swiping user (fromUid).
      allow create, update: if signedIn()
        && request.resource.data.fromUid == request.auth.uid
        && swipeId == request.resource.data.fromUid + '_' + request.resource.data.toUid;
      // Readable by either side of the swipe (needed for mutual-connect check).
      allow read: if signedIn()
        && (resource.data.fromUid == request.auth.uid
            || resource.data.toUid == request.auth.uid);
      allow delete: if false;
    }

    // Match doc id is the sorted uid pair joined by "_".
    match /matches/{matchId} {
      // Readable only by members.
      allow read: if signedIn() && request.auth.uid in resource.data.memberUids;
      // Creatable by a member who includes themselves in memberUids.
      allow create: if signedIn()
        && request.auth.uid in request.resource.data.memberUids;
      // lastMessage/lastSentAt updates by members only.
      allow update: if signedIn() && request.auth.uid in resource.data.memberUids;
      allow delete: if false;

      // Messages readable/writable only by match members.
      match /messages/{messageId} {
        allow read: if signedIn()
          && request.auth.uid in get(/databases/$(database)/documents/matches/$(matchId)).data.memberUids;
        allow create: if signedIn()
          && request.resource.data.fromUid == request.auth.uid
          && request.auth.uid in get(/databases/$(database)/documents/matches/$(matchId)).data.memberUids;
        allow update, delete: if false;
      }
    }

    // Block doc id is `${blockerUid}_${blockedUid}`.
    match /blocks/{blockId} {
      // Writable by the blocker only.
      allow create: if signedIn()
        && request.resource.data.blockerUid == request.auth.uid;
      allow read: if signedIn() && resource.data.blockerUid == request.auth.uid;
      allow update, delete: if false;
    }

    // Reports are append-only for any authenticated user.
    match /reports/{reportId} {
      allow create: if signedIn()
        && request.resource.data.reporterUid == request.auth.uid;
      allow read, update, delete: if false;
    }
  }
}
