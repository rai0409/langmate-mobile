// ============================================================
// LangMate — production-oriented Firestore security rules
// ============================================================
// Canonical, deployable rules file. Mirrors the data model written by the
// repositories in src/repositories/* (the source of truth):
//   profiles/{uid}                       (setDoc merge; fields incl. uid, isDiscoverable)
//   swipes/{fromUid}_{toUid}             (setDoc; fromUid, toUid, action, createdAt)
//   matches/{sortedUidA}_{sortedUidB}    (Function-created; matchId, memberUids[2], createdAt, updatedAt; + lastMessage/lastSentAt on update)
//   matches/{matchId}/messages/{autoId}  (addDoc; fromUid, text, createdAt)
//   matches/{matchId}/memberStates/{uid} (setDoc merge; unreadCount, lastReadAt, muted)
//   entitlements/{uid}                   (read-only client entitlement; defaults to free if absent)
//   blocks/{blockerUid}_{blockedUid}     (setDoc; blockerUid, blockedUid, createdAt)
//   reports/{autoId}                     (addDoc; reporterUid, reportedUid, reason, createdAt)
//   reportReviews/{reportId}             (admin-only review metadata; client denied)
//   moderationReviews/{reviewId}         (admin-only review events; client denied)
//   userModeration/{uid}                 (admin-only user status; client denied)
//   accountDeletionRequests/{uid}        (owner request record; no actual deletion)
//
// VALIDATION & DEPLOY:
//   - These rules have been exercised with the Firebase Emulator Suite
//     (npm run test:rules). Re-run after any change.
//   - Deploy manually only AFTER review:
//       firebase deploy --only firestore:rules
//   - Prompt007 did NOT deploy these to the real project.
//
// PRODUCTION CAVEATS:
//   - Mutual-connect match creation is handled by Cloud Functions/Admin SDK
//     after validating both swipe documents. Client match creation is denied.
//   - Reports are create-only from clients; reading/acting on them must be
//     done by admin/moderation tooling (Admin SDK / Cloud Functions, which
//     bypass these rules). No client may read reports.
//   - Moderation review/status collections are explicitly client-denied until
//     a server-backed custom-claims admin model is implemented and tested.
//   - Account deletion requests are only request records. Actual deletion and
//     retention handling require a future Admin SDK / Cloud Functions workflow.
//   - Client-side block filtering in the app is UX, not security; these
//     rules are the actual boundary.
// ============================================================

rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function isMember(memberUids) {
      return signedIn() && request.auth.uid in memberUids;
    }

    // ----------------------------------------------------------
    // profiles/{uid} — main profile, always keyed by the auth uid.
    // ----------------------------------------------------------
    match /profiles/{uid} {
      // Owner reads own profile; any signed-in user reads discoverable ones.
      allow read: if signedIn()
        && (request.auth.uid == uid || resource.data.isDiscoverable == true);
      // Only the owner may write, and the embedded uid must match the doc id
      // (covers both create and the merge-based edit-profile update).
      allow create, update: if signedIn()
        && request.auth.uid == uid
        && request.resource.data.uid == uid;
      allow delete: if false;
    }

    // Device-scoped Expo push tokens. Token values are private to the owner;
    // delivery state remains server-only because Admin SDK bypasses rules.
    match /users/{uid}/pushTokens/{deviceId} {
      function validPushTokenFields() {
        return request.resource.data.keys().hasOnly([
          'uid', 'token', 'platform', 'deviceId', 'enabled', 'createdAt',
          'updatedAt', 'lastSeenAt', 'invalidatedAt', 'invalidReason'
        ])
          && request.resource.data.uid == uid
          && request.resource.data.deviceId == deviceId
          && request.resource.data.token is string
          && request.resource.data.token.size() > 0
          && request.resource.data.platform in ['ios', 'android']
          && request.resource.data.enabled is bool;
      }
      allow get: if signedIn() && request.auth.uid == uid;
      allow list: if false;
      allow create: if signedIn() && request.auth.uid == uid && validPushTokenFields();
      allow update: if signedIn() && request.auth.uid == uid
        && validPushTokenFields()
        && request.resource.data.uid == resource.data.uid
        && request.resource.data.deviceId == resource.data.deviceId
        && request.resource.data.platform == resource.data.platform
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'token', 'enabled', 'updatedAt', 'lastSeenAt', 'invalidatedAt', 'invalidReason'
        ]);
      allow delete: if false;
    }

    // ----------------------------------------------------------
    // swipes/{fromUid}_{toUid}
    // ----------------------------------------------------------
    match /swipes/{swipeId} {
      // Only the swiping user writes; fromUid cannot be spoofed; the doc id
      // must equal fromUid_toUid; action is constrained to the app's values.
      allow create, update: if signedIn()
        && request.resource.data.fromUid == request.auth.uid
        && request.resource.data.toUid is string
        && request.resource.data.toUid != request.auth.uid
        && request.resource.data.action in ['connect', 'skip']
        && swipeId == request.resource.data.fromUid + '_' + request.resource.data.toUid;
      // The mutual-connect check reads the incoming swipe via get(); that doc
      // may not exist yet, so allow a get on a non-existent swipe (returns
      // "not found", leaks nothing). For an existing swipe, only the two
      // parties may read it.
      allow get: if signedIn()
        && (resource == null
            || resource.data.fromUid == request.auth.uid
            || resource.data.toUid == request.auth.uid);
      // The app never lists swipes; if it ever does, restrict to a party.
      allow list: if signedIn()
        && (resource.data.fromUid == request.auth.uid
            || resource.data.toUid == request.auth.uid);
      allow delete: if false;
    }

    // ----------------------------------------------------------
    // matches/{sortedUidA_sortedUidB}
    // ----------------------------------------------------------
    match /matches/{matchId} {
      // The Connect flow may wait on this deterministic doc before it exists,
      // so allow a get on a non-existent match (returns "not found", leaks
      // nothing). For an existing match, only members may read it.
      allow get: if signedIn()
        && (resource == null || request.auth.uid in resource.data.memberUids);
      // The Matches screen lists via where(memberUids array-contains uid);
      // members only (the query constraint guarantees membership).
      allow list: if isMember(resource.data.memberUids);
      allow create: if false;
      // Members may update only the chat-summary fields; membership is
      // immutable from the client (memberUids can never be in the diff).
      allow update: if isMember(resource.data.memberUids)
        && request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['lastMessage', 'lastSentAt', 'updatedAt']);
      allow delete: if false;

      // --------------------------------------------------------
      // matches/{matchId}/messages/{autoId}
      // --------------------------------------------------------
      function matchMembers() {
        return get(/databases/$(database)/documents/matches/$(matchId)).data.memberUids;
      }

      match /messages/{messageId} {
        // Members only.
        allow read: if isMember(matchMembers());
        // Members create their own messages with non-empty text.
        allow create: if isMember(matchMembers())
          && request.resource.data.fromUid == request.auth.uid
          && request.resource.data.text is string
          && request.resource.data.text.size() > 0;
        allow update, delete: if false;
      }

      // --------------------------------------------------------
      // matches/{matchId}/memberStates/{uid}
      // --------------------------------------------------------
      match /memberStates/{uid} {
        function validMemberStateKeys() {
          return request.resource.data.keys().hasOnly([
            'unreadCount',
            'lastReadAt',
            'muted',
            'updatedAt'
          ]);
        }

        function validMemberStateValues() {
          return (!('unreadCount' in request.resource.data)
              || (request.resource.data.unreadCount is int
                  && request.resource.data.unreadCount >= 0))
            && (!('muted' in request.resource.data)
              || request.resource.data.muted is bool);
        }

        function ownMemberStateWrite() {
          return request.auth.uid == uid
            && validMemberStateKeys()
            && validMemberStateValues();
        }

        allow read: if signedIn()
          && request.auth.uid == uid
          && uid in matchMembers();
        // Clients may only write their own member state. Recipient unread
        // increments are server-authority work handled by Functions/Admin SDK.
        allow create: if signedIn()
          && uid in matchMembers()
          && ownMemberStateWrite();
        allow update: if signedIn()
          && uid in matchMembers()
          && ownMemberStateWrite();
        allow delete: if false;
      }
    }

    // ----------------------------------------------------------
    // entitlements/{uid} — optional read-only client entitlement.
    // ----------------------------------------------------------
    match /entitlements/{uid} {
      allow get: if signedIn() && request.auth.uid == uid;
      allow list, create, update, delete: if false;
    }

    // ----------------------------------------------------------
    // blocks/{blockerUid}_{blockedUid}
    // ----------------------------------------------------------
    match /blocks/{blockId} {
      // Only the blocker creates their own block; doc id must match contents.
      allow create, update: if signedIn()
        && request.resource.data.blockerUid == request.auth.uid
        && request.resource.data.blockedUid is string
        && request.resource.data.blockedUid != request.auth.uid
        && blockId == request.resource.data.blockerUid + '_' + request.resource.data.blockedUid;
      // Both sides may read (two-direction block filtering needs the blocked
      // user to see the incoming block).
      allow read: if signedIn()
        && (resource.data.blockerUid == request.auth.uid
            || resource.data.blockedUid == request.auth.uid);
      // No unblock flow exists in the app yet.
      allow delete: if false;
    }

    // ----------------------------------------------------------
    // reports/{autoId} — append-only from clients.
    // ----------------------------------------------------------
    match /reports/{reportId} {
      allow create: if signedIn()
        && request.resource.data.reporterUid == request.auth.uid
        && request.resource.data.reportedUid is string
        && request.resource.data.reason is string
        && request.resource.data.reason.size() > 0;
      // Reads/mutations only via admin tooling (Admin SDK bypasses rules).
      allow read, update, delete: if false;
    }

    // ----------------------------------------------------------
    // Admin-only moderation data. These collections are reserved
    // for future Admin SDK / Cloud Functions workflows.
    // ----------------------------------------------------------
    match /reportReviews/{reportId} {
      allow read, write: if false;
    }

    match /moderationReviews/{reviewId} {
      allow read, write: if false;
    }

    match /userModeration/{uid} {
      allow read, write: if false;
    }

    // ----------------------------------------------------------
    // accountDeletionRequests/{uid} — non-destructive request intake.
    // ----------------------------------------------------------
    match /accountDeletionRequests/{uid} {
      function validDeletionRequest() {
        return request.resource.data.keys().hasOnly([
            'uid','requestId','status','requestedAt','scheduledFor','reasonCategory',
            'retentionPolicyVersion','requestedBy','updatedAt'
          ])
          && request.resource.data.uid == uid
          && request.resource.data.status == 'requested'
          && request.resource.data.requestId == uid
          && request.resource.data.requestedBy == uid;
      }

      // Users may create/read/update only their own request record.
      // Listing all requests and deleting data remain server/admin work.
      allow get: if signedIn() && request.auth.uid == uid;
      allow list: if false;
      allow create: if signedIn()
        && request.auth.uid == uid
        && validDeletionRequest();
      allow update: if signedIn() && request.auth.uid == uid
        && resource.data.status in ['requested','scheduled']
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status','cancelledAt','updatedAt'])
        && request.resource.data.status == 'cancelled';
      allow delete: if false;
    }

    match /accountDeletionAudit/{auditId} { allow read, write: if false; }

    // ----------------------------------------------------------
    // Default deny: any path not matched above.
    // ----------------------------------------------------------
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
