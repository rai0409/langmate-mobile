{
  "name": "langexchange_mobile",
  "version": "1.0.0",
  "main": "index.ts",
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/bottom-tabs": "^7.18.0",
    "@react-navigation/native": "^7.3.1",
    "@react-navigation/native-stack": "^7.17.3",
    "expo": "~56.0.11",
    "expo-image-picker": "~56.0.19",
    "expo-status-bar": "~56.0.4",
    "firebase": "^12.14.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.85.3",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-web": "^0.21.2"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^5.0.1",
    "@types/react": "~19.2.2",
    "firebase-tools": "^15.20.0",
    "typescript": "~6.0.3"
  },
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "web:8080": "expo start --web --port 8080 -c",
    "web:8080:host": "expo start --web --host 0.0.0.0 --port 8080 -c",
    "test:types": "tsc --noEmit",
    "test:rules": "firebase emulators:exec --only firestore --project demo-langmate \"node rules-tests/firestore.test.mjs\"",
    "test:functions:unread": "npm --prefix functions run build && firebase emulators:exec --only firestore,functions --project demo-langmate \"node scripts/functions_unread_e2e.mjs\"",
    "moderation:fixture": "node scripts/moderation_review_fixture.mjs",
    "account-deletion:fixture": "node scripts/account_deletion_request_fixture.mjs"
  },
  "private": true
}
